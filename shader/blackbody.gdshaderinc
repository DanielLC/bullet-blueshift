vec3 get_color_blackbody(float temperature, float intensity) {
	temperature = clamp(temperature, 1000, 39999);	// I only have data between these ranges. Though it should probably just return black for anything colder.
	float x = (temperature - 1000.0)/100.0;
	int i = int(x);
	float t = x - float(i);
	vec4 color = BLACKBODY[i]*(1.0-t) + BLACKBODY[i+1]*t;
	// Now I have a linear approximation of rgb and power. I could just multiply it, but obviously that would be way too much.
	float power = color.w * pow(intensity, 0.125);
	float relPower = color.w / (color.w + 1e15);
	return color.rgb * pow(relPower, 0.125);
}